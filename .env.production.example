# Production — copy to /var/www/sentinel/.env on the VPS and set strong secrets.
#   cp .env.production.example .env
#   chmod 600 .env

# ── Postgres ───────────────────────────────────────────────────────────────────
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=change-me-use-openssl-rand
POSTGRES_DB=sentinel

# Hostname `postgres` is the Docker service name on sentinel-internal.
DATABASE_URL=postgresql://sentinel:change-me-use-openssl-rand@postgres:5432/sentinel?schema=public

# ── Deploy output (build.sh) ───────────────────────────────────────────────────
PUBLIC_HOST=sentinel.djm-apps.com

# ── Telemetry (optional — uncomment when enabling collector/agent in prod) ───
# GRPC_HOST=0.0.0.0
# GRPC_PORT=50051
# AGENT_ID=prod-agent-1
# COLLECTOR_GRPC_URL=collector:50051
# METRICS_INTERVAL_MS=10000
# GRPC_RPC_TIMEOUT_MS=5000
# TICK_TIMEOUT_MS=8000
# LOG_LEVEL=info
