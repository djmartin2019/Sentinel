# Local development — copy to repo root .env (git-ignored):
#   cp .env.example .env
#
# Use host 127.0.0.1 in DATABASE_URL when running ./dev.sh or pnpm on your machine.
# Use host postgres only inside Docker containers (see docker-compose.yml).

# ── Postgres ───────────────────────────────────────────────────────────────────
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel
POSTGRES_DB=sentinel
DATABASE_URL=postgresql://sentinel:sentinel@127.0.0.1:5432/sentinel?schema=public

# ── Dashboard / API / Checker (host dev) ─────────────────────────────────────
NODE_ENV=development
# PORT=4010

# ── Telemetry agent (host dev → docker collector on 50051) ─────────────────────
AGENT_ID=local-agent
COLLECTOR_GRPC_URL=127.0.0.1:50051
METRICS_INTERVAL_MS=10000
GRPC_RPC_TIMEOUT_MS=5000
TICK_TIMEOUT_MS=8000

# ── Telemetry collector (host dev) ───────────────────────────────────────────
GRPC_HOST=0.0.0.0
GRPC_PORT=50051

# ── Shared logging ───────────────────────────────────────────────────────────
LOG_LEVEL=info
