generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CheckStatus {
    UP
    DOWN
}

model HealthCheck {
    id              String          @id @default(cuid())

    targetId        String
    target          MonitoredTarget @relation(fields: [targetId], references: [id])

    status          CheckStatus

    statusCode      Int?
    latencyMs       Int?
    errorMessage    String?

    checkedAt       DateTime        @default(now())

    @@index([checkedAt])
    @@index([targetId, checkedAt(sort: Desc)])
}

model MonitoredTarget {
    id          String      @id @default(cuid())
    name        String
    url         String
    interval    Int         @default(30)
    createdAt   DateTime    @default(now())

    checks              HealthCheck[]
    incidents           Incident[]
    aggregates5m        HealthCheckAggregate5m[]
    aggregatesHourly    HealthCheckAggregateHourly[]
    aggregatesDaily     HealthCheckAggregateDaily[]
}

model HealthCheckAggregate5m {
    id            String          @id @default(cuid())

    targetId      String
    target        MonitoredTarget @relation(fields: [targetId], references: [id])

    bucketStart   DateTime

    totalChecks   Int
    upChecks      Int
    downChecks    Int

    avgLatencyMs  Float?
    minLatencyMs  Int?
    maxLatencyMs  Int?
    p95LatencyMs  Int?
    p99LatencyMs  Int?

    createdAt     DateTime        @default(now())
    updatedAt     DateTime        @updatedAt

    @@unique([targetId, bucketStart])
    @@index([bucketStart])
    @@index([targetId, bucketStart])
}

model HealthCheckAggregateHourly {
    id            String          @id @default(cuid())

    targetId      String
    target        MonitoredTarget @relation(fields: [targetId], references: [id])

    bucketStart   DateTime

    totalChecks   Int
    upChecks      Int
    downChecks    Int

    avgLatencyMs  Float?
    minLatencyMs  Int?
    maxLatencyMs  Int?
    p95LatencyMs  Int?
    p99LatencyMs  Int?

    createdAt     DateTime        @default(now())
    updatedAt     DateTime        @updatedAt

    @@unique([targetId, bucketStart])
    @@index([bucketStart])
    @@index([targetId, bucketStart])
}

model HealthCheckAggregateDaily {
    id            String          @id @default(cuid())

    targetId      String
    target        MonitoredTarget @relation(fields: [targetId], references: [id])

    bucketStart   DateTime

    totalChecks   Int
    upChecks      Int
    downChecks    Int

    avgLatencyMs  Float?
    minLatencyMs  Int?
    maxLatencyMs  Int?
    p95LatencyMs  Int?
    p99LatencyMs  Int?

    createdAt     DateTime        @default(now())
    updatedAt     DateTime        @updatedAt

    @@unique([targetId, bucketStart])
    @@index([bucketStart])
    @@index([targetId, bucketStart])
}

model Incident {
    id          String          @id @default(cuid())

    targetId    String
    target      MonitoredTarget @relation(fields: [targetId], references: [id])

    title       String
    severity    String
    description String

    startedAt   DateTime
    resolvedAt  DateTime?
    downCount   Int             @default(0)

    createdAt   DateTime        @default(now())
    updatedAt   DateTime        @updatedAt

    @@index([resolvedAt])
    @@index([targetId, resolvedAt])
    @@index([startedAt])
}

model TelemetryMetric {
    id          String      @id @default(cuid())
    agentId     String
    metricType  String
    value       Float
    recordedAt  DateTime    @default(now())

    @@index([agentId, metricType, recordedAt])
}
